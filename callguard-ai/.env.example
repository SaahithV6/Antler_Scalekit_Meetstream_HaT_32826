# MeetStream
MEET_STREAM_API_KEY=your_meetstream_api_key

# Scalekit — from app.scalekit.com → Settings → API Credentials
SCALEKIT_ENV_URL=https://your-env.scalekit.dev
SCALEKIT_CLIENT_ID=your_client_id
SCALEKIT_CLIENT_SECRET=your_client_secret

# Scalekit connection names — must match exactly what you named them in the dashboard
JIRA_CONNECTION_NAME=jira
GMAIL_CONNECTION_NAME=gmail

# Jira project key (the short prefix on your Jira tickets e.g. CG or CALL)
JIRA_PROJECT_KEY=CG

# Email address that receives escalation alerts
ESCALATION_EMAIL=manager@yourcompany.com

# Unique identifier for the authorized user (your email or "user-001" for testing)
IDENTIFIER=user-001

# Set to "true" only during local development — never in production
FLASK_DEBUG=false
