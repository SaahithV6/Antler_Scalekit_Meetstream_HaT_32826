# MeetStream
MEETSTREAM_API_KEY=
MEETSTREAM_BOT_NAME=Meeting Copilot
MIA_AGENT_CONFIG_ID=         # Optional — MIA agent config from MeetStream dashboard

# Transcription
DEEPGRAM_API_KEY=

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Scalekit Agent Auth
SCALEKIT_ENV_URL=https://your-env.scalekit.cloud
SCALEKIT_CLIENT_ID=skc_...
SCALEKIT_CLIENT_SECRET=sks_...

# App
AUTHORIZED_USER_NAME=         # Speaker name to listen for yes/no confirmation
WEBHOOK_URL=                  # Public ngrok URL for MeetStream webhook callbacks
PORT=3001
WS_PORT=3002
FRONTEND_URL=http://localhost:3000

# Jira
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_PROJECT_KEY=ENG

# User
DEFAULT_USER_ID=user_001      # Default identifier for Scalekit connected accounts
